{
    "manifest_version": 3,
    "name": "Poketwo Image Forwarder (Firefox)",
    "version": "1.0",
    "description": "Detects Poketwo spawns and asks Gemini to identify Pokémon from image files.",
    "permissions": [
        "tabs"
    ],
    "host_permissions": [
        "https://*.discord.com/*",
        "https://*.discordapp.com/*",
        "https://*.discordapp.net/*",
        "https://generativelanguage.googleapis.com/*"
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.discord.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "page-bridge.js"
            ],
            "matches": [
                "https://*.discord.com/*",
                "https://*.discordapp.com/*",
                "https://*.discordapp.net/*"
            ]
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "poketwo-forwarder@local-dev"
        }
    }
}